generator client {
  provider = "prisma-client-js"
}

datasource db {
provider = "postgresql"
url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  SUPERVISOR
  COLABORADOR
}

enum CheckInStatus {
  VALIDO
  FORA_DA_CERCA
  FRAUDE_DETECTADA
}

model User {
  id        String    @id @default(uuid())
  name      String
  email     String    @unique
  password  String    // hash bcrypt
  role      Role      @default(COLABORADOR)
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  visits    Visit[]
  sessions  Session[]

  @@map("users")
}

model Client {
  id        String   @id @default(uuid())
  name      String
  address   String
  latitude          Float
  longitude         Float
  statusOperacional String   @default("PENDENTE")
  createdAt         DateTime @default(now())

  visits    Visit[]

  @@map("clients")
}

model Visit {
  id              String        @id @default(uuid())
  userId          String
  clientId        String
  
  capturedLat     Float
  capturedLng     Float
  gpsAccuracy     Float         // acima de 50m indica sinal ruim ou gps fake
  
  // resultado do calculo haversine
  distanceToDest  Float
  status          CheckInStatus
  isMocked        Boolean       // true se gps simulado foi detectado
  
  deviceTimestamp DateTime      
  serverTimestamp DateTime      @default(now())

  user            User          @relation(fields: [userId], references: [id])
  client          Client        @relation(fields: [clientId], references: [id])
  auditLogs       AuditLog[]

  @@index([userId, serverTimestamp])
  @@map("visits")
}

model AuditLog {
  id          String   @id @default(uuid())
  visitId     String?
  action      String
  description String
  ipAddress   String?
  createdAt   DateTime @default(now())

  visit       Visit?   @relation(fields: [visitId], references: [id])

  @@map("audit_logs")
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  refreshToken String   @unique
  deviceInfo   String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// autenticacao por username/password, sem fluxo de e-mail
model Usuario {
  id        String    @id @default(uuid())
  nome      String
  username  String    @unique
  password  String    // hash bcrypt, nunca texto puro
  role      String    // ex: 'ADMIN', 'AGENTE'
  createdAt DateTime  @default(now())

  checkins  Checkin[]

  @@map("usuarios")
}

model Checkin {
  id             String   @id @default(uuid())
  colaboradorId  String   // fk para Usuario.id
  clienteId      String
  latitude       Float
  longitude      Float
  isMocked       Boolean
  status         String
  alertaGeofence Boolean
  createdAt      DateTime @default(now())

  colaborador    Usuario  @relation(fields: [colaboradorId], references: [id])

  @@index([colaboradorId, createdAt])
  @@map("checkins")
}